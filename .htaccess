Options -MultiViews -Indexes

DirectoryIndex index.html

RewriteEngine On

# Legacy blog page redirect to new paginated blog list.
RewriteRule ^blog-page-2/?$ /blog?page=2 [R=301,L,NC]
RewriteRule ^blog-page-2/index\.html$ /blog?page=2 [R=301,L,NC]
RewriteRule ^blog-page-2\.html$ /blog?page=2 [R=301,L,NC]

# Redirect /index.html (root or nested) to extensionless URL.
RewriteCond %{THE_REQUEST} \s/+(.*/)?index\.html(?:[\s?]|$) [NC]
RewriteRule ^ %1 [R=301,L]

# Redirect explicit .html requests to extensionless URLs.
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html(?:[\s?]|$) [NC]
RewriteRule ^ %1 [R=301,L]

# Internally map extensionless URLs to existing .html files.
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
